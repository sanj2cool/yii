omponents\UserAccessControl.php";s:4:"line";i:34;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\BaseController.php";s:4:"line";i:20;s:8:"function";s:11:"checkAccess";s:5:"class";s:32:"app\components\UserAccessControl";s:4:"type";s:2:"::";}}i:5;i:6328072;}i:18;a:6:{i:0;s:28:"SHOW CREATE TABLE `tbl_menu`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1774627808.043137;i:4;a:2:{i:0;a:5:{s:4:"file";s:62:"C:\laragons\www\hkmis\yii2app\components\UserAccessControl.php";s:4:"line";i:34;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\BaseController.php";s:4:"line";i:20;s:8:"function";s:11:"checkAccess";s:5:"class";s:32:"app\components\UserAccessControl";s:4:"type";s:2:"::";}}i:5;i:6330520;}i:20;a:6:{i:0;s:772:"SELECT
    `kcu`.`CONSTRAINT_NAME` AS `constraint_name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `referenced_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `referenced_column_name`
FROM `information_schema`.`REFERENTIAL_CONSTRAINTS` AS `rc`
JOIN `information_schema`.`KEY_COLUMN_USAGE` AS `kcu` ON
    (
        `kcu`.`CONSTRAINT_CATALOG` = `rc`.`CONSTRAINT_CATALOG` OR
        (`kcu`.`CONSTRAINT_CATALOG` IS NULL AND `rc`.`CONSTRAINT_CATALOG` IS NULL)
    ) AND
    `kcu`.`CONSTRAINT_SCHEMA` = `rc`.`CONSTRAINT_SCHEMA` AND
