:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:5981424;}i:15;a:6:{i:0;s:608:"SELECT SUM(subquery.current_qty) AS `total_qty` FROM (SELECT `p`.`id`, IFNULL((SELECT SUM(pr.no_of_items)
                     FROM tbl_product_receiving pr
                     WHERE pr.fk_product_id = p.id AND pr.status = 1 and pr.fk_location_id = 1), 0)
             - IFNULL((SELECT SUM(it.quantity)
                       FROM tbl_invoice_item it
                       WHERE it.fk_product_id = p.id AND it.status = 1 AND it.fk_invoice_id in (select id from tbl_invoice where fk_bill_from_id = 1)), 0)
             AS current_qty FROM `tbl_product` `p` WHERE `p`.`status`=1 GROUP BY `p`.`id`) `subquery`";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.508616;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:40;s:8:"function";s:6:"scalar";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:6272096;}i:18;a:6:{i:0;s:38:"SELECT * FROM `tbl_user` WHERE `id`=21";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.633252;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:43;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:6953472;}i:21;a:6:{i:0;s:33:"SHOW FULL COLUMNS FROM `tbl_user`";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.634398;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:43;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:6967272;}i:24;a:6:{i:0;s:28:"SHOW CREATE TABLE `tbl_user`";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.636153;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:43;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:6985136;}i:27;a:6:{i:0;s:772:"SELECT
    `kcu`.`CONSTRAINT_NAME` AS `constraint_name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `referenced_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `referenced_column_name`
FROM `information_schema`.`REFERENTIAL_CONSTRAINTS` AS `rc`
JOIN `information_schema`.`KEY_COLUMN_USAGE` AS `kcu` ON
    (
        `kcu`.`CONSTRAINT_CATALOG` = `rc`.`CONSTRAINT_CATALOG` OR
        (`kcu`.`CONSTRAINT_CATALOG` IS NULL AND `rc`.`CONSTRAINT_CATALOG` IS NULL)
    ) AND
    `kcu`.`CONSTRAINT_SCHEMA` = `rc`.`CONSTRAINT_SCHEMA` AND
    `kcu`.`CONSTRAINT_NAME` = `rc`.`CONSTRAINT_NAME`
WHERE `rc`.`CONSTRAINT_SCHEMA` = database() AND `kcu`.`TABLE_SCHEMA` = database()
AND `rc`.`TABLE_NAME` = 'tbl_user' AND `kcu`.`TABLE_NAME` = 'tbl_user'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.637605;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:43;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:7005344;}i:30;a:6:{i:0;s:364:"SELECT SUM(i.total_amount - COALESCE(ap.total_amount_paid, 0)) AS `total_outstanding` FROM `tbl_vendor_invoice` `i` LEFT JOIN (SELECT `fk_vendor_invoice_id`, SUM(amount_received) AS `total_amount_paid` FROM `tbl_vendor_account_payable` GROUP BY `fk_vendor_invoice_id`) `ap` ON i.id = ap.fk_vendor_invoice_id WHERE (`i`.`status` != 0) AND (`i`.`fk_location_id`='1')";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.641908;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:88;s:8:"function";s:6:"scalar";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:7030976;}i:33;a:6:{i:0;s:537:"SELECT SUM(CASE
          WHEN ROUND(i.total_amount - COALESCE(ir.total_amount_received, 0), 2) < 0
          THEN 0
          ELSE ROUND(i.total_amount - COALESCE(ir.total_amount_received, 0), 2)
          END) AS total_outstanding FROM `tbl_invoice` `i` LEFT JOIN (SELECT `ir`.`fk_invoice_id`, ROUND(SUM(ir.amount_received), 2) AS `total_amount_received` FROM `tbl_account_receivable` `ir` WHERE `ir`.`status` != 0 GROUP BY `ir`.`fk_invoice_id`) `ir` ON i.id = ir.fk_invoice_id WHERE (`i`.`status` != 0) AND (`i`.`fk_bill_from_id`='1')";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.645782;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:123;s:8:"function";s:6:"scalar";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:7038432;}i:36;a:6:{i:0;s:121:"SELECT count(*) FROM `tbl_purchase_order` WHERE (`status` != 0) AND (purchase_status in (1,2)) AND (`fk_location_id`='1')";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.663062;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:143;s:8:"function";s:6:"scalar";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:7040784;}i:39;a:6:{i:0;s:191:"SELECT * FROM `tbl_attendance` WHERE (`fk_user_id`=21) AND (`date`='2026-03-27') AND (`fk_location_id`='1') ORDER BY UNIX_TIMESTAMP(STR_TO_DATE(CONCAT(date," ",in_time), "%Y-%m-%d %h:%i %p"))";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.6644;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:183;s:8:"function";s:3:"all";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s