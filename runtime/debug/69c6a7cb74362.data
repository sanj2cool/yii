y = 21) AND (due_date <= "2026-03-27")";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.716846;i:4;a:2:{i:0;a:5:{s:4:"file";s:52:"C:\laragons\www\hkmis\yii2app\views\layouts\main.php";s:4:"line";i:250;s:8:"function";s:3:"all";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:8104672;}i:233;a:6:{i:0;s:643:"SELECT `p`.`name` AS `product_name`, `p`.`id` AS `product_id`, `p`.`description` AS `description`, `p`.`sku` AS `product_sku`, (IFNULL(SUM(pr.no_of_items), 0) - IFNULL(SUM(pa.no_of_items), 0)) AS `current_qty`, GROUP_CONCAT(DISTINCT pr.fk_bin_id SEPARATOR ", ") AS `product_location`, `p`.`quantity_in_stock` AS `reorder_qty` FROM `tbl_product` `p` LEFT JOIN `tbl_product_receiving` `pr` ON p.id = pr.fk_product_id AND pr.status != 0 LEFT JOIN `tbl_product_allotment` `pa` ON p.id = pa.fk_product_id AND pa.status != 0 WHERE p.status != 0 GROUP BY `p`.`id` HAVING current_qty < (p.quantity_in_stock * 0.80) ORDER BY `current_qty` DESC LIMIT 10";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.716954;i:4;a:2:{i:0;a:5:{s:4:"file";s:52:"C:\laragons\www\hkmis\yii2app\views\layouts\main.php";s:4:"line";i:353;s:8:"function";s:3:"all";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:8109144;}i:234;a:6:{i:0;s:643:"SELECT `p`.`name` AS `product_name`, `p`.`id` AS `product_id`, `p`.`description` AS `description`, `p`.`sku` AS `product_sku`, (IFNULL(SUM(pr.no_of_items), 0) - IFNULL(SUM(pa.no_of_items), 0)) AS `current_qty`, GROUP_CONCAT(DISTINCT pr.fk_bin_id SEPARATOR ", ") AS `product_location`, `p`.`quantity_in_stock` AS `reorder_qty` FROM `tbl_product` `p` LEFT JOIN `tbl_product_receiving` `pr` ON p.id = pr.fk_product_id AND pr.status != 0 LEFT JOIN `tbl_product_allotment` `pa` ON p.id = pa.fk_product_id AND pa.status != 0 WHERE p.status != 0 GROUP BY `p`.`id` HAVING current_qty < (p.quantity_in_stock * 0.80) ORDER BY `current_qty` DESC LIMIT 10";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.760666;i:4;a:2:{i:0;a:5:{s:4:"file";s:52:"C:\laragons\www\hkmis\yii2app\views\layouts\main.php";s:4:"line";i:353;s:8:"function";s:3:"all";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:8116496;}i:236;a:6:{i:0;s:634:"SELECT `p`.`name` AS `product_name`, `p`.`id` AS `product_id`, `p`.`description` AS `description`, `p`.`sku` AS `product_sku`, (IFNULL(SUM(pr.no_of_items), 0) - IFNULL(SUM(pa.no_of_items), 0)) AS `current_qty`, GROUP_CONCAT(DISTINCT pr.fk_bin_id SEPARATOR ", ") AS `product_location`, `p`.`quantity_in_stock` AS `reorder_qty` FROM `tbl_product` `p` LEFT JOIN `tbl_product_receiving` `pr` ON p.id = pr.fk_product_id AND pr.status != 0 LEFT JOIN `tbl_product_allotment` `pa` ON p.id = pa.fk_product_id AND pa.status != 0 WHERE p.status != 0 GROUP BY `p`.`id` HAVING current_qty < p.quantity_in_stock ORDER BY `current_qty` DESC LIMIT 10";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.760878;i:4;a:2:{i:0;a:5:{s:4:"file";s:52:"C:\laragons\www\hkmis\yii2app\views\layouts\main.php";s:4:"line";i:413;s:8:"function";s:3:"all";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:8138376;}i:237;a:6:{i:0;s:634:"SELECT `p`.`name` AS `product_name`, `p`.`id` AS `product_id`, `p`.`description` AS `description`, `p`.`sku` AS `product_sku`, (IFNULL(SUM(pr.no_of_items), 0) - IFNULL(SUM(pa.no_of_items), 0)) AS `current_qty`, GROUP_CONCAT(DISTINCT pr.fk_bin_id SEPARATOR ", ") AS `product_location`, `p`.`quantity_in_stock` AS `reorder_qty` FROM `tbl_product` `p` LEFT JOIN `tbl_product_receiving` `pr` ON p.id = pr.fk_product_id AND pr.status != 0 LEFT JOIN `tbl_product_allotment` `pa` ON p.id = pa.fk_product_id AND pa.status != 0 WHERE p.status != 0 GROUP BY `p`.`id` HAVING current_qty < p.quantity_in_stock ORDER BY `current_qty` DESC LIMIT 10";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.807935;i:4;a:2:{i:0;a:5:{s:4:"file";s:52:"C:\laragons\www\hkmis\yii2app\views\layouts\main.php";s:4:"line";i:413;s:8:"function";s:3:"all";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:8145640;}}}";s:2:"db";s:94853:"a:1:{s:8:"messages";a:148:{i:16;a:6:{i:0;s:608:"SELECT SUM(subquery.current_qty) AS `total_qty` FROM (SELECT `p`.`id`, IFNULL((SELECT SUM(pr.no_of_items)
                     FROM tbl_product_receiving pr
                     WHERE pr.fk_product_id = p.id AND pr.status = 1 and pr.fk_location_id = 1), 0)
             - IFNULL((SELECT SUM(it.quantity)
                       FROM tbl_invoice_item it
                       WHERE it.fk_product_id = p.id AND it.status = 1 AND it.fk_invoice_id in (select id from tbl_invoice where fk_bill_from_id = 1)), 0)
             AS current_qty FROM `tbl_product` `p` WHERE `p`.`status`=1 GROUP BY `p`.`id`) `subquery`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1774626763.508654;i:4;a:2:{i:0;a:5:{s:4:"file";s:50:"C:\laragons\www\hkmis\yii2app\views\site\index.php";s:4:"line";i:40;s:8:"function";s:6:"scalar";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:60:"C:\laragons\www\hkmis\yii2app\controllers\SiteController.php";s:4:"line";i:86;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:6273688;}i:17;a:6:{i:0;s:608:"SELECT SUM(subquery.current_qty) AS `total_qty` FROM (SELECT `p`.`id`, IFNULL((SELECT SUM(pr.no_of_items)
